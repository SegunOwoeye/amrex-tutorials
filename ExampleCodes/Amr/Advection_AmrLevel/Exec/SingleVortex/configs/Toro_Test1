# ------------------  INPUTS TO MAIN PROGRAM  -------------------
max_step  = 1000000
stop_time = 0.25

# PROBLEM SIZE & GEOMETRY (2D)
geometry.coord_sys   = 0
geometry.prob_lo     = 0.0  0.0
geometry.prob_hi     = 1.0  1.0

# Toro test should be non-periodic in x, periodic in y
geometry.is_periodic = 0  1

# Resolution
amr.n_cell           = 104  8

# TIME STEP CONTROL
adv.cfl = 0.3
# (match your 1D config first; you can increase later)

# VERBOSITY
adv.v = 1
amr.v = 1

# REFINEMENT / REGRIDDING
amr.max_level       = 1 # Set to 0 for no AMR and 1 or more AMR enabled
amr.regrid_int      = 2
amr.n_error_buf     = 2
amr.blocking_factor = 8
amr.max_grid_size   = 256

# PLOTFILES
amr.plot_files_output = 1
amr.plot_file         = plt
amr.plot_int          = 20
# (0.25 / ~0.0014 ≈ 170 steps, so plot every 20 is fine)

# CHECKPOINT FILES
amr.checkpoint_files_output = 0

# TRACERS
adv.do_tracers = 0

# For amr =comment out when not in use
amr.n_error_buf = 2
amr.regrid_int  = 2

adv.do_reflux = 0

adv.max_rhograd_lev = 1
adv.rho_grad = 0.02 0.01 0.005